# Centralised environment variables for ETL benchmarks
# Generated by: make setup-local
# Copy to .env and adjust as needed, or let setup-local.sh generate it.

# Source database
ORIGIN_ADDRESS=localhost
ORIGIN_PORT=5434
ORIGIN_DB=postgres
ORIGIN_USER=postgres
ORIGIN_PASS=postgres

# Target database
TARGET_ADDRESS=localhost
TARGET_PORT=5433
TARGET_DB=target
TARGET_USER=postgres
TARGET_PASS=postgres

# Sling connection strings
SOURCEDB=postgresql://postgres:postgres@localhost:5434/postgres
TARGETDB=postgresql://postgres:postgres@localhost:5433/target
